# Banco de dados (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# NextAuth — o login do web é por token (gerado no app). Estes segredos
# continuam necessários para assinar a sessão.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=gere_um_segredo_longo_aleatorio
# Alias aceito pela Vercel/NextAuth (mesmo valor do AUTH_SECRET)
NEXTAUTH_SECRET=

# Vercel KV (Upstash Redis) — OBRIGATÓRIO em produção. Sustenta o rate limit do
# login/sync e o lock distribuído de sync entre instâncias serverless. Sem KV em
# produção a app falha fechado nesses caminhos (auditoria #44). Em dev/local pode
# ficar vazio: cai para um fallback em memória por instância.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Segredo para cifrar o token de acesso da casa em repouso (auditoria #43).
# Use um valor aleatório longo (>= 16 chars). NÃO rotacione sem re-migrar os
# tokens existentes (apps/web/scripts/migrar-invite-code.mjs), senão login/sync
# param de bater e o perfil não decifra o token.
INVITE_TOKEN_SECRET=gere_um_segredo_longo_aleatorio
