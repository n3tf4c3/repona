# Banco de dados (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# NextAuth — o login do web é por token (gerado no app). Em produção a URL
# precisa usar HTTPS. Os segredos precisam ter pelo menos 32 caracteres.
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=substitua_por_segredo_aleatorio_com_32_chars_ou_mais
# Alias aceito pela Vercel/NextAuth (mesmo valor do AUTH_SECRET)
NEXTAUTH_SECRET=

# Segredo para cifrar o token de acesso da casa em repouso (auditoria #43).
# Use um valor aleatório longo (>= 32 chars). NÃO rotacione sem re-migrar os
# tokens existentes (apps/web/scripts/migrar-invite-code.mjs), senão login/sync
# param de bater e o perfil não decifra o token.
INVITE_TOKEN_SECRET=substitua_por_segredo_aleatorio_com_32_chars_ou_mais

# Senha do painel admin (/admin), protegido por HTTP Basic Auth no middleware.
# Use um valor aleatório longo (>= 32 chars). Sem ele o painel responde 503.
# No prompt do navegador, qualquer usuário serve; a senha é este valor.
ADMIN_SECRET=substitua_por_segredo_aleatorio_com_32_chars_ou_mais

# Opcional (>= 32 chars): pepper dedicado para fingerprints do rate limit.
# Quando vazio/ausente, o servidor deriva um pepper separado de
# INVITE_TOKEN_SECRET via HKDF; um valor definido e curto é erro de configuração.
RATE_LIMIT_PEPPER=

# Tokens legados (8 ou 12 caracteres) deixam de autenticar login/sync nesta data.
# A migração explícita possui hard end compilado em 2027-04-01 UTC.
LEGACY_TOKEN_ACCEPT_UNTIL=2027-01-01T00:00:00.000Z
