# Banco de dados (Neon / PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=gere_um_segredo_longo_aleatorio
# Alias aceito pela Vercel/NextAuth (mesmo valor do AUTH_SECRET)
NEXTAUTH_SECRET=

# Usuário inicial criado pelo script db:seed:usuario (rodar localmente)
SEED_EMAIL=voce@exemplo.com
SEED_PASSWORD=troque_esta_senha
SEED_NOME=Paulo
