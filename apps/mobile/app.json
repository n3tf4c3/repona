{
  "expo": {
    "name": "Repona",
    "slug": "repona",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "repona",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.repona.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Permita que o Repona tire fotos e leia códigos de barras dos produtos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "41b243b3-7246-4f71-a173-fe6fd6e3eb3f"
      }
    }
  }
}
